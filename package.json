{
  "name": "pictronic-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "rm -rf .next .next-build && NEXT_DIST_DIR=.next-build next build && cp -a .next-build .next",
    "build:isolated": "NEXT_DIST_DIR=.next-build next build",
    "start": "next start",
    "lint": "next lint",
    "ops:pm2:start": "npx --yes pm2 start ops/runtime/ecosystem.config.cjs",
    "ops:pm2:restart": "npx --yes pm2 restart ops/runtime/ecosystem.config.cjs",
    "ops:pm2:stop": "npx --yes pm2 delete pictronic-runtime bridge-connector bridge-watchdog",
    "ops:watchdog": "python3 ops/runtime/watchdog.py",
    "ops:env:check": "bash ops/runtime/verify-runtime-env.sh",
    "ops:skills:resolve": "bash ops/skills/resolve-skill-conflicts.sh",
    "ops:bridge:auth:check": "bash ops/runtime/verify-bridge-auth.sh",
    "ops:bridge-auth:smoke": "python3 ops/runtime/bridge_auth_smoke.py",
    "ops:insomnia:guardrail:check": "python3 ops/runtime/verify_insomnia_guardrail.py",
    "ops:runtime:contract:check": "python3 ops/runtime/jup94_infinite_scroll_guardrail.py --paperclip-api-key \"$PAPERCLIP_API_KEY\"",
    "ops:auth:guest-isolation:check": "bash ops/runtime/jup103_guest_isolation_regression.sh",
    "ops:jup106:closeout": "python3 ops/runtime/jup106_closeout_drill.py"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@supabase/supabase-js": "^2.103.0",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "14.2.33",
    "next-themes": "^0.4.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-masonry-css": "^1.0.16",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "20.16.12",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.6.3"
  }
}
