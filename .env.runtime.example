# Unified runtime env contract for managed runtime + bridge processes.
# Copy to .env.runtime (or set PICTRONIC_RUNTIME_ENV_FILE to an absolute path).

# Public runtime env (available in browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_PIC_API_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_PIC_MOCK=false

# Server/runtime env
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
REDIS_URL=redis://127.0.0.1:6379/0
COMFYUI_URL=http://127.0.0.1:8188
OLLAMA_URL=http://127.0.0.1:11434

# Bridge security
BRIDGE_BOOTSTRAP_KEY=bridge-bootstrap-dev
BRIDGE_ADMIN_KEY=bridge-admin-dev

# Bridge connector identity + auth
NODE_ID=node-local-01
MACHINE_ID=machine-local-01
CONNECTION_TOKEN=
POLL_INTERVAL_SECONDS=3
LEASE_TTL_SECONDS=30

# Optional preflight toggles
PREFLIGHT_REQUIRE_REDIS_BULLMQ=true
PREFLIGHT_REQUIRE_COMFYUI=true
PREFLIGHT_REQUIRE_OLLAMA=true

# Optional integration test knob
PICTRONIC_ADOBE_FAIL_ATTEMPTS=0
