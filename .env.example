# Public runtime env (available in browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_PIC_API_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_PIC_MOCK=false

# Server/local runtime env
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
REDIS_URL=redis://127.0.0.1:6379/0
COMFYUI_URL=http://127.0.0.1:8188
OLLAMA_URL=http://127.0.0.1:11434
BRIDGE_BOOTSTRAP_KEY=bridge-bootstrap-dev
BRIDGE_ADMIN_KEY=bridge-admin-dev

# Optional preflight toggles
PREFLIGHT_REQUIRE_REDIS_BULLMQ=true
PREFLIGHT_REQUIRE_COMFYUI=true
PREFLIGHT_REQUIRE_OLLAMA=true

# Optional integration test knob
PICTRONIC_ADOBE_FAIL_ATTEMPTS=0
